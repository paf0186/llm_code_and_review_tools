[Unit]
Description=Lustre Patch Watcher
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=patchwatcher
ExecStart=/shared/llm_code_and_review_tools/patch_watcher/run_watcher.sh
TimeoutStartSec=600
Environment=HOME=/home/patchwatcher
Environment=PATH=/home/patchwatcher/.local/bin:/usr/local/bin:/usr/bin:/bin
WorkingDirectory=/shared/llm_code_and_review_tools/patch_watcher
